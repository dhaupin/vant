# VANT Environment Variables
# Copy to .env and fill in your values
# Never commit .env to version control!

# GitHub Token (create at: https://github.com/settings/tokens)
# Required scopes: repo
GITHUB_TOKEN=your_github_token_here

# Stegoframe (optional - for room transport)
STEGOFRAME_ROOM=your_room_id
STEGOFRAME_PASSPHRASE=your_passphrase

# Runtime (optional overrides)
# POLLING_INTERVAL=10000
# MAX_REQUESTS_PER_HOUR=360